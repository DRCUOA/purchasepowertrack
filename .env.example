# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/basket_tracker

# === OpenAI ===
OPENAI_API_KEY=sk-...

# === Server ===
PORT=3000
NODE_ENV=development

# === Frontend (build-time) ===
VITE_API_BASE_URL=http://localhost:3000

# === Refresh Job ===
# Comma-separated adapter keys to enable
# Options: openai-search (AI web search), woolworths (direct API), paknsave (stub)
ENABLED_RETAILERS=openai-search

# === Settings ===
BASELINE_MONTH=2026-04
