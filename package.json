{
  "name": "nz-basket-tracker",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "test": "npm run test -w server",
    "migrate": "npm run migrate -w server",
    "seed": "npm run seed -w server",
    "refresh": "npm run refresh -w server",
    "snapshot": "npm run snapshot -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
